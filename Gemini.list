# Gemini / Google AI — Classical rules
# Common format for OpenClash / Quantumult X / Shadowrocket
# Ensures full functionality: web app, AI Studio, API, authentication, assets

# ====================
# Core Gemini domains
# ====================

# Gemini Web App
DOMAIN-SUFFIX,gemini.google.com

# Google AI Studio
DOMAIN-SUFFIX,aistudio.google.com

# Gemini API backend (critical)
DOMAIN-SUFFIX,generativelanguage.googleapis.com

# Google AI developer docs
DOMAIN-SUFFIX,ai.google.dev

# ====================
# Google Auth / Account
# ====================

DOMAIN-SUFFIX,accounts.google.com
DOMAIN-SUFFIX,accounts.youtube.com

# ====================
# Google API infrastructure
# ====================

DOMAIN-SUFFIX,www.googleapis.com
DOMAIN-SUFFIX,apis.google.com
DOMAIN-SUFFIX,googleapis.com
DOMAIN-SUFFIX,clients6.google.com

# Gemini-specific API endpoints
DOMAIN-SUFFIX,jnn-pa.googleapis.com
DOMAIN-SUFFIX,waa-pa.clients6.google.com
DOMAIN-SUFFIX,ogads-pa.clients6.google.com

# ====================
# Content delivery / CDN
# ====================

# User content / images
DOMAIN-SUFFIX,lh3.googleusercontent.com
DOMAIN-SUFFIX,lh5.googleusercontent.com
DOMAIN-SUFFIX,lh3.google.com

# Static assets
DOMAIN-SUFFIX,ssl.gstatic.com
DOMAIN-SUFFIX,fonts.gstatic.com
DOMAIN-SUFFIX,maps.gstatic.com
DOMAIN-SUFFIX,fonts.googleapis.com
DOMAIN-SUFFIX,maps.googleapis.com
DOMAIN-SUFFIX,i.ytimg.com
DOMAIN-SUFFIX,yt3.ggpht.com

# ====================
# Other Google services Gemini depends on
# ====================

DOMAIN-SUFFIX,ogs.google.com
DOMAIN-SUFFIX,csp.withgoogle.com
DOMAIN-SUFFIX,www.googletagmanager.com
DOMAIN-SUFFIX,play.google.com
DOMAIN-SUFFIX,www.google.com

# ====================
# Broad keyword match (catch-all)
# ====================

DOMAIN-KEYWORD,gemini
DOMAIN-KEYWORD,aistudio
DOMAIN-KEYWORD,generativelanguage
