# Direct.list
# 手动指定直连域名
#
# 用途：给“本来会掉到兜底分流、但实际应直连”的域名做修正规则。
# 规则在 fallback.yaml 中应放在明确分流规则之后、MATCH 兜底之前。
#
# 常用格式：
# DOMAIN-SUFFIX,example.com
# DOMAIN,exact.example.com
# DOMAIN-KEYWORD,example

DOMAIN-KEYWORD,vo0
DOMAIN-KEYWORD,zhimeisj
DOMAIN-KEYWORD,iposl
DOMAIN-SUFFIX,ma.vo0.site
DOMAIN-SUFFIX,str.vo0.site
DOMAIN-SUFFIX,ppa.iposl.com

# 小红书图片/主站直连
DOMAIN-SUFFIX,xhscdn.com
DOMAIN-SUFFIX,xiaohongshu.com

# 腾讯地图直连（微信定位等）
DOMAIN-SUFFIX,map.qq.com
DOMAIN-SUFFIX,apis.map.qq.com
DOMAIN-SUFFIX,pr.map.qq.com
DOMAIN-SUFFIX,rt.map.qq.com
DOMAIN-SUFFIX,sv.map.qq.com

# xqjzvcvt 直连
DOMAIN-SUFFIX,xqjzvcvt
DOMAIN-SUFFIX,xqjzvcvt.top